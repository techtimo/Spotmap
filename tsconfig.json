{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "strict": true,
        "esModuleInterop": true,
        "rootDir": "./src",
        "outDir": "build",
        "declaration": false,
        "sourceMap": true,
        "lib": [ "ES2022", "DOM" ]
    },
    "include": [ "src/**/*" ],
    "exclude": [ "node_modules", "build", "src/**/__tests__/**/*" ]
}
