{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"strict": true,
		"esModuleInterop": true,
		"outDir": "build",
		"declaration": false,
		"sourceMap": true,
		"lib": [ "ES2020", "DOM" ]
	},
	"include": [ "src/**/*" ],
	"exclude": [ "node_modules", "build" ]
}
